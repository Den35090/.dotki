{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "left",
  "positionY": "top",
  "layer": "overlay",
  "controlCenterWidth": 400,
  "controlCenterHeight": 200,
  "controlCenterMarginTop": 50,
  "controlCenterMarginBottom": 80,
  "controlCenterMarginRight": 10,
  "controlCenterMarginLeft": 0,
  "notificationBodyHeight": 100,
  "timeout": 5,
  "timeoutLow": 2,
  "timeoutCritical": 0,
  "fitToScreen": true,
  "controlCenterExclusive": false,
  "widgets": [
    "mpris",
    "title",
    "dnd",
    "buttons-grid",
    "notifications"
  ],
  "widget-config": {
    "mpris": {
      "image-size": 96,
      "image-radius": 12
    },
    "dnd": {
      "text": "Do not disturb"
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰂯",
          "command": "rfkill toggle bluetooth"
        },
        {
          "label": "󰖩",
          "command": "nmcli radio wifi toggle"
        },
        {
          "label": "󰔎",
          "command": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
        },
        {
          "label": "󰄛",
          "command": "hyprlock"
        }
      ]
    }
  }
}