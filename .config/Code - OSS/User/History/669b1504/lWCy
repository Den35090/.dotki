@define-color cc-green #74D600;
@define-color bg-dark rgba(10, 10, 10, 0.8);

* {
    font-family: "CodeNewRoman Nerd Font Propo";
    font-size: 15px;
    border: none;
    border-radius: 0;
}

window#waybar {
    background: transparent;
}

.modules-left, .modules-center, .modules-right {
    padding: 2px 10px;
    margin: 10px 5px 5px 5px;
    border-radius: 10px;
    background: @bg-dark;
    border: 1px solid alpha(@cc-green, 0.3);
}

/* Визуализатор CAVA */
#custom-cava {
    color: @cc-green;
    padding: 0 10px;
    font-family: "monospace"; /* Для правильного отображения баров */
}

#workspaces button {
    padding: 0 5px;
    color: alpha(@cc-green, 0.4);
}

#workspaces button.active {
    color: @cc-green;
    text-shadow: 0px 0px 5px @cc-green;
}

/* Модули для ПК */
#clock, #cpu, #memory, #temperature, #network, #tray, #pulseaudio {
    padding: 0 8px;
    color: white;
}

#clock:hover, #cpu:hover, #memory:hover, #network:hover, #pulseaudio:hover {
    color: @cc-green;
    transition: 0.3s;
}

/* Тултипы */
tooltip {
    background: @bg-dark;
    border: 1px solid @cc-green;
}
tooltip label {
    color: white;
}