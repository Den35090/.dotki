{
  "positionX": "left",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "width": 350,
  "height": 600,
  "timeout": 5,
  "timeout-low": 2,
  "timeout-critical": 0,
  "notification-visibility": {
    "urgency-low": { "state": "show" },
    "urgency-normal": { "state": "show" },
    "urgency-critical": { "state": "show" }
  },
  "widgets": [
    "buttons-grid",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "buttons-grid": {
      "actions": [
        { "label": "󰂯", "command": "bluetoothctl toggle" },
        { "label": "󰖩", "command": "nm-connection-editor" },
        { "label": "󰂜", "command": "swaync-client -C" }
      ]
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 12
    }
  }
}
