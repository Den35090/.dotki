{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "style": "/home/surfiks/.config/swaync/style.css",
  "positionX": "left",
  "positionY": "top",
  "layer": "overlay",
  "control-center-margin-top": 0,
  "control-center-margin-bottom": 450,
  "control-center-margin-right": 0,
  "control-center-margin-left": 0,
  "notificationBodyHeight": 100,
  "timeout": 5,
  "timeoutLow": 2,
  "timeoutCritical": 0,
  "fitToScreen": true,
  "controlCenterExclusive": false,
  "widgets": [
    "mpris",
    "buttons-grid",
    "volume",
    "notifications"
  ],
  "volume": {
      "label": "󰕾",
      "show-per-app-icon": true,
      "show-per-app": true
    },
  "widget-config": {
    "mpris": {
      "image-size": 96,
      "image-radius": 12
    },
    "dnd": {
      "text": "Do not disturb"
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰕾",
          "type": "toggle",
          "command": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
          "update-command": "wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q 'MUTED' && echo true || echo false"
        },
        {
          "label": "",
          "command": "hyprlock"
        }
      ]
    }
  }
}