{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": {
	"source": "~/.config/fastfetch/logo.jpg",
	"type": "kitty-icat",
	"width": 40,
	"height": 15,
	"padding": {
	  "top": 0,
	  "left": 0
	}
  },
  "modules": [
    "title",
    "os",
    "host",
    "uptime",
    "packages",
    "de",
    "wm",
    "terminal",
    "cpu",
    "gpu",
    "memory",
    "locale",
    "break",
    "colors"
  ]
}
